    },
    "amount": {
      "type": "number",
      "description": "\u0645\u0628\u0644\u063a \u0627\u0644\u062f\u0641\u0639\u0629"
    },
    "payment_date": {
      "type": "string",
      "format": "date",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0633\u062f\u0627\u062f"
    },
    "notes": {
      "type": "string",
      "description": "\u0645\u0644\u0627\u062d\u0638\u0627\u062a"
    }
  },
  "required": [
