      "type": "string",
      "description": "\u0643\u0648\u062f \u0627\u0644\u0635\u0646\u0641"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "\u0647\u0644 \u0627\u0644\u0635\u0646\u0641 \u0646\u0634\u0637"
    }
